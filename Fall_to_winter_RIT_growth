CREATE TABLE student_scores (
    student_first_name TEXT,
    grade INTEGER,
    subject TEXT,
    course TEXT,
    fall_rit_score REAL,
    fall_rapid_guessing_pct REAL,
    winter_rit_score REAL,
    winter_rapid_guessing_pct REAL,
    rit_growth REAL
);

