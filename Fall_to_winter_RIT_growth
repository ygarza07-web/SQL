-- I calculated average growth from fall to winter
SELECT grade,
       AVG(rit_growth)AS avg_growth
FROM student_scores
GROUP BY grade;
-- I placed scores in range
SELECT student_first_name,
       grade,
       fall_rit_score,
       winter_rit_score,
       rit_growth
FROM student_scores
WHERE winter_rit_score < 190
   OR rit_growth <= 0;
   
   SELECT student_first_name,
       grade,
       rit_growth,
       CASE
           WHEN rit_growth >= 6 THEN 'high growth'
           WHEN rit_growth >= 1 THEN 'Some Growth'
           ELSE 'Low or Negative Growth'
       END AS growth_category
FROM student_scores;
